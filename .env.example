# Получить бесплатно на openweathermap.org
OPENWEATHER_API_KEY=your_key_here

# Получить бесплатно на newsapi.org
NEWS_API_KEY=your_key_here

# AI news collector
NEWS_SOURCES_FILE=ai-service/data/news_sources.json
NEWS_CACHE_DB_PATH=ai-service/data/news_cache.sqlite3
NEWS_COLLECTOR_POLL_SECONDS=300
NEWS_COLLECTOR_FRESH_SECONDS=900
NEWS_ROUTE_DISCOVERY_FRESH_SECONDS=900
NEWS_ROUTE_LOCALITIES_LIMIT=8
NEWS_ROUTE_GEOCODE_POINTS=4
NEWS_RETENTION_DAYS=14
NEWS_HTTP_TIMEOUT_SECONDS=20
